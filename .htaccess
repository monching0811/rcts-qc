SetEnv SUPABASE_ANON_KEY "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImlwanRycWNuY3l2bXR6cmJzanlhIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzI2NDI0NTMsImV4cCI6MjA4ODIxODQ1M30.BLSGY7O-uXRf-OTiFwb1Vq05I3ZdG-D82tzXp64fGrQ"
SetEnv SUPABASE_SERVICE_ROLE_KEY "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImlwanRycWNuY3l2bXR6cmJzanlhIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3MjY0MjQ1MywiZXhwIjoyMDg4MjE4NDUzfQ.oZtMHlzG57tZHkpFKvFT5oqKZ9PVfVTgH6t2S10DKdI"
SetEnv S9_SUPABASE_URL "https://nhnynmdhamvspyujjpws.supabase.co"
SetEnv S9_SUPABASE_SERVICE_ROLE_KEY "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im5obnlubWRoYW12c3B5dWpqcHdzIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3MzQ2MzE3OCwiZXhwIjoyMDg5MDM5MTc4fQ.j7gfUTF-G2riitI13k-N9OYcRymeNnchC3KF06Wniys"

# PayMongo Environment Variables
SetEnv PAYMONGO_API_KEY "pk_test_1dvaGURJpDphXHM41rTfSWR7"
SetEnv PAYMONGO_WEBHOOK_SECRET "whsk_6yZ8eB2V7bM6iqF26k5FGsNi"

# ── PHP error display (dev mode) ─────────────────────────────
php_flag  display_errors      On
php_value error_reporting     E_ALL
php_flag  log_errors           On
php_value error_log           logs/php-errors.log

# ── CORS headers for API endpoints ───────────────────────────
<IfModule mod_headers.c>
    # Allow same-origin + localhost dev
    Header always set Access-Control-Allow-Origin  "*"
    Header always set Access-Control-Allow-Methods "GET, POST, OPTIONS"
    Header always set Access-Control-Allow-Headers "Content-Type, X-API-Key, Authorization"
    Header always set Access-Control-Max-Age       "3600"

    # Handle pre-flight OPTIONS
    RewriteCond %{REQUEST_METHOD} OPTIONS
    RewriteRule .* - [R=204,L]
</IfModule>

# ── mod_rewrite for clean API routing ────────────────────────
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /rcts-qc/

    # Pass all /api/ requests directly to PHP files
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^api/(.*)$ api/$1 [L,QSA]

    # Pass all /mock-data/ requests directly
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^mock-data/(.*)$ mock-data/$1 [L,QSA]
</IfModule>

# ── Security headers ──────────────────────────────────────────
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options        "SAMEORIGIN"
    Header set Referrer-Policy        "strict-origin-when-cross-origin"
</IfModule>

# ── Deny access to sensitive files ───────────────────────────
<FilesMatch "\.(env|log|json|sql)$">
    <RequireAll>
        Require local
    </RequireAll>
</FilesMatch>

# Allow JSON mock data files to be fetched by the app
<Files "citizens.json">
    Require all granted
</Files>
<Files "properties.json">
    Require all granted
</Files>