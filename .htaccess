# ============================================================

# RCTS-QC | .htaccess

# XAMPP / Apache configuration for the RCTS-QC project.

# Place this in the root of the project folder:

# C:/xampp/htdocs/rcts-qc/.htaccess

# ============================================================

# Allow all requests within this folder

Options -Indexes +FollowSymLinks

# Environment Variables for Supabase

# NOTE: Set these environment variables in your server configuration (InfinityFree control panel, .env file, etc.)

# Never commit actual secrets to source control

# SetEnv SUPABASE_URL "https://your-project.supabase.co"

# SetEnv SUPABASE_ANON_KEY "your-anon-key-here"

# SetEnv SUPABASE_SERVICE_ROLE_KEY "your-service-role-key-here"

# SetEnv S9_SUPABASE_URL "https://your-s9-project.supabase.co"

# SetEnv S9_SUPABASE_SERVICE_ROLE_KEY "your-s9-service-role-key-here"

# PayMongo Environment Variables

# NOTE: Set these environment variables in your server configuration

# SetEnv PAYMONGO_API_KEY "your-paymongo-api-key-here"

# SetEnv PAYMONGO_WEBHOOK_SECRET "your-paymongo-webhook-secret-here"

# ── PHP error display (dev mode) ─────────────────────────────

php_flag display_errors On
php_value error_reporting E_ALL
php_flag log_errors On
php_value error_log logs/php-errors.log

# ── CORS headers for API endpoints ───────────────────────────

<IfModule mod_headers.c>
    # Allow same-origin + localhost dev
    Header always set Access-Control-Allow-Origin  "*"
    Header always set Access-Control-Allow-Methods "GET, POST, OPTIONS"
    Header always set Access-Control-Allow-Headers "Content-Type, X-API-Key, Authorization"
    Header always set Access-Control-Max-Age       "3600"

    # Handle pre-flight OPTIONS
    RewriteCond %{REQUEST_METHOD} OPTIONS
    RewriteRule .* - [R=204,L]

</IfModule>

# ── mod_rewrite for clean API routing ────────────────────────

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /rcts-qc/

    # Pass all /api/ requests directly to PHP files
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^api/(.*)$ api/$1 [L,QSA]

    # Pass all /mock-data/ requests directly
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^mock-data/(.*)$ mock-data/$1 [L,QSA]

</IfModule>

# ── Security headers ──────────────────────────────────────────

<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options        "SAMEORIGIN"
    Header set Referrer-Policy        "strict-origin-when-cross-origin"
    Header set X-XSS-Protection       "1; mode=block"
    
    # Remove dangerous headers that might trigger warnings
    Header unset X-Powered-By
</IfModule>

# ── Deny access to sensitive files ───────────────────────────

<FilesMatch "\.(env|log|json|sql)$">
<RequireAll>
Require local
</RequireAll>
</FilesMatch>

# Allow JSON mock data files to be fetched by the app

<Files "citizens.json">
Require all granted
</Files>
<Files "properties.json">
Require all granted
</Files>
